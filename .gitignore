# Business repos live here but are independent — never tracked by agent-cortex.
/repositories/

# Feature worktrees (created alongside repos under repositories/).
*.worktrees/

# External (installed) resources + their lockfiles — keep the template clean.
/skills/
/agents/

# Local cortex-mem audit store.
/.cortex-mem/

# Generated tool symlink dirs — rebuilt from knowledge/ + externals via:
#   scripts/cortex relink   (or: scripts/cortex install, after a fresh clone)
/.claude/skills/
/.claude/agents/
/.cursor/agents/
/.opencode/agent/
/.agents/skills/

/node_modules/

/.tmp

# OS / editor cruft
.DS_Store
*.swp
